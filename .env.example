# Supabase Postgres — Project Settings → Database → Connection string
# 1) DATABASE_URL: the "Transaction" pooler connection (port 6543) — used by the app at runtime
DATABASE_URL="postgresql://postgres.xxxxxxxx:[email protected]:6543/postgres?pgbouncer=true&connection_limit=1"

# 2) DIRECT_URL: the direct connection (port 5432) — used only by `prisma migrate` / `prisma db push`
DIRECT_URL="postgresql://postgres.xxxxxxxx:[email protected]:5432/postgres"

# Secret used to sign JWT session tokens — generate with: openssl rand -base64 32
JWT_SECRET="change-me-to-a-long-random-string"

# Base URL of the deployed app, used in invite emails
APP_URL="https://app.drivero.eu"

# Shared secret for the /api/cron/check-deadlines endpoint (Vercel sends this automatically
# for its own Cron Jobs if you set the same value in Project Settings → Environment Variables)
CRON_SECRET="change-me-too"

# Supabase Storage — Project Settings → API. Service role key bypasses Storage RLS,
# used server-side only by lib/supabase-storage.ts for handover-photo uploads.
SUPABASE_URL="https://xxxxxxxx.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"
